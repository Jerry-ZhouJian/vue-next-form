{
  "name": "vue-next-form",
  "version": "1.0.7",
  "type": "module",
  "description": "A configurable form component based on Vue 3 and Element Plus",
  "main": "./dist/vue-next-form.umd.js",
  "module": "./dist/vue-next-form.es.js",
  "style": "./dist/vue-next-form.css",
  "exports": {
    ".": {
      "import": "./dist/vue-next-form.es.js",
      "require": "./dist/vue-next-form.umd.js"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "vue-next-form",
    "vue3",
    "element-plus",
    "configurable-form"
  ],
  "author": "Jerry Chow",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "prepare": "npm run build"
  },
  "dependencies": {
    "axios": "^1.9.0",
    "element-plus": "^2.9.7"
  },
  "peerDependencies": {
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/tsconfig": "^0.7.0",
    "sass-embedded": "^1.89.0",
    "typescript": "~5.7.2",
    "unplugin-element-plus": "^0.9.1",
    "vite": "^6.3.5",
    "vite-plugin-dts": "^4.5.4",
    "vue-tsc": "^2.2.4"
  }
}
